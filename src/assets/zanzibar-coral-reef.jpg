<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="coralGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#006994"/>
      <stop offset="100%" style="stop-color:#4a90e2"/>
    </linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#coralGradient)"/>
  <text x="400" y="200" textAnchor="middle" fill="white" fontFamily="Arial, sans-serif" fontSize="32" fontWeight="bold">Zanzibar Coral Reefs</text>
  <text x="400" y="250" textAnchor="middle" fill="white" fontFamily="Arial, sans-serif" fontSize="20">🌊 Marine Biodiversity</text>
  <circle cx="400" cy="350" r="80" stroke="white" strokeWidth="3" fill="none"/>
</svg>