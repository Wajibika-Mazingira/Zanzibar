<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="solarGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ff9800"/>
      <stop offset="100%" style="stop-color:#ffc107"/>
    </linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#solarGradient)"/>
  <text x="400" y="200" textAnchor="middle" fill="white" fontFamily="Arial, sans-serif" fontSize="32" fontWeight="bold">Zanzibar Solar Energy</text>
  <text x="400" y="250" textAnchor="middle" fill="white" fontFamily="Arial, sans-serif" fontSize="20">☀️ Renewable Power</text>
  <rect x="250" y="350" width="300" height="100" stroke="white" strokeWidth="3" fill="none"/>
</svg>